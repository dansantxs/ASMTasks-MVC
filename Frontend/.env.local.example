# URL base da API do backend (sem barra no final)
# Dev local: use HTTP para evitar conflito de esquema de cookies (http://localhost:3000 -> http://localhost:5273)
NEXT_PUBLIC_API_URL=http://localhost:5273/api
# Produção/Docker: use o proxy do Next.js ou a URL pública
# NEXT_PUBLIC_API_URL=https://seudominio.com/api
